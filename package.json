{
  "name": "pg-qbuild",
  "version": "0.0.1",
  "private": true,
  "description": "A small SQL-first TypeScript query builder for PostgreSQL.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:test": "tsc -p test/tsconfig.json --noEmit",
    "test": "tsc -p test/tsconfig.json && find dist-test/test -name '*.test.js' -print0 | xargs -0 -r node --test"
  },
  "keywords": [
    "typescript",
    "postgres",
    "sql",
    "query-builder"
  ],
  "engines": {
    "node": ">=24"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  }
}
